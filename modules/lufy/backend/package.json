{
  "name": "lufy-backend",
  "version": "1.0.0",
  "description": "lufy.cc URL Shortener Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
