// This is your Prisma schema file for lufy.cc

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  links        Link[]
}

// ─── Links ───────────────────────────────────────────────────────────────────
model Link {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug           String   @unique
  type           String   @default("simple") // simple | split | device
  status         String   @default("active") // active | paused | expired
  comment        String?

  // Simple link
  destinationUrl String?

  // Device targeting
  desktopUrl     String?
  mobileUrl      String?

  // Split traffic (JSON: [{url: string, weight: number}])
  targets        String   @default("[]")

  clickCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clicks         Click[]
}

// ─── Clicks ──────────────────────────────────────────────────────────────────
model Click {
  id         String   @id @default(cuid())
  linkId     String
  link       Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  slug       String
  ip         String?
  country    String?
  os         String?
  browser    String?
  device     String?
  deviceType String?  // mobile | desktop | tablet
  referrer   String?
  asn        String?
  asName     String?
  asDomain   String?
  continent  String?
  createdAt  DateTime @default(now())
}
