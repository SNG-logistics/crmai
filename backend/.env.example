# =============================================
# Database
# =============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/crm_db?schema=public"

# =============================================
# Redis
# =============================================
REDIS_URL="redis://localhost:6379"

# =============================================
# JWT Authentication (LEGACY — kept for migration fallback)
# =============================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# Keep the old username/password JWT login working during migration.
# Set to "false" once everyone signs in through Firebase.
ALLOW_LEGACY_JWT="true"

# =============================================
# Firebase Admin (server) — verifies ID tokens & manages Firebase Auth users
# =============================================
FIREBASE_PROJECT_ID="crmlao"
# Service-account JSON as a single env var (raw JSON or base64). Get it from:
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=""
# Alternative: point to a service-account file instead of the inline JSON above
# GOOGLE_APPLICATION_CREDENTIALS="./serviceAccount.json"

# =============================================
# Platform Owner (npm run setup-owner)
# =============================================
OWNER_EMAIL="kengplsz@gmail.com"
OWNER_TENANT_SLUG="demo"
# Optional — set a password to also allow email/password login for the owner.
# Leave empty for Google-only sign-in.
OWNER_PASSWORD=""

# =============================================
# CometAPI (OpenAI-compatible AI)
# =============================================
COMETAPI_KEY="your-cometapi-key-here"
COMETAPI_BASE_URL="https://api.cometapi.com/v1"
COMETAPI_MODEL="gpt-4o"

# =============================================
# LINE Messaging API
# =============================================
LINE_CHANNEL_SECRET="your-line-channel-secret"
LINE_CHANNEL_ACCESS_TOKEN="your-line-channel-access-token"

# =============================================
# Telegram Bot API
# =============================================
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# =============================================
# Server Configuration
# =============================================
PORT=4000
NODE_ENV="development"

# =============================================
# Frontend Configuration
# =============================================
FRONTEND_URL="http://localhost:3000"

# =============================================
# Super Admin Account (seed script)
# =============================================
SUPER_ADMIN_EMAIL="superadmin@crm.com"
SUPER_ADMIN_PASSWORD="SuperAdmin@123"

# =============================================
# File Upload
# =============================================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10mb"

# =============================================
# Rate Limiting
# =============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# =============================================
# Slip Verification (SlipOK)
# =============================================
SLIPOK_API_KEY="your-slipok-api-key"
SLIPOK_BRANCH_ID="your-slipok-branch-id"

# =============================================
# Bot anti-spam guard (กัน "มือบ่อน" ถามซ้ำเผา token)
# ถ้าลูกค้าถามความหมายเดิมซ้ำครบ THRESHOLD ครั้ง → ตอบ auto ครั้งเดียวแล้วสลับเป็น human
# (ตรวจจากข้อความในฐานข้อมูล ไม่เรียก AI จึงไม่เสีย token)
# =============================================
BOT_REPEAT_GUARD=true
BOT_REPEAT_THRESHOLD=3
BOT_REPEAT_WINDOW=6
BOT_REPEAT_MINLEN=6
BOT_REPEAT_SIMILARITY=0.8
BOT_REPEAT_REPLY="ขอโอนให้เจ้าหน้าที่ดูแลต่อนะคะ รอสักครู่ค่ะ 🙏😊"
